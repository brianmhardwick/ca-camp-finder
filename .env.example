# -------------------------------------------------------
# CA Camp Finder — Environment Configuration
# Copy this file to .env and fill in your values.
# Never commit .env to git.
# -------------------------------------------------------

# Pushover credentials (https://pushover.net)
PUSHOVER_USER_KEY=your_user_key_here
PUSHOVER_API_TOKEN=your_app_api_token_here

# Check intervals (minutes)
# Default: every hour; Peak window (Thu/Fri + evenings): every 15 min
DEFAULT_CHECK_INTERVAL=60
PEAK_WINDOW_INTERVAL=15

# How many days ahead to scan for Fri/Sat/Sun availability
SCAN_DAYS_AHEAD=90

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
